{
    "compilerOptions": {
        "esModuleInterop": true,
        "module": "commonjs",
        "target": "ES2019",
        "lib": [
            "ES2020",
            "es5",
            "es6",
            "dom"
        ],
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
        "resolveJsonModule": true,
        "types": ["node", "@wdio/globals/types", "@wdio/visual-service", "mocha"],
        "strictPropertyInitialization": false
    },
    "exclude": [
        "dist",
        "node_modules",
        "wdio.conf.ts"
    ]
}