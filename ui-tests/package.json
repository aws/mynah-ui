    },
    "dependencies": {
        "@aws/mynah-ui": "file:../"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.7",
        "@wdio/cli": "^9.0.9",
        "@wdio/local-runner": "^9.0.9",
        "@wdio/mocha-framework": "^9.0.8",
        "@wdio/types": "^9.0.8",
        "@wdio/visual-service": "^6.0.0",
        "eslint": "^9.10.0",
        "eslint-plugin-wdio": "^9.0.8",
        "html-webpack-plugin": "^5.5.0",
        "raw-loader": "^4.0.2",
        "ts-loader": "^9.4.4",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.4",
        "wdio": "^6.0.1",
        "webpack": "^5.61.0",
        "webpack-cli": "^4.7.2"
