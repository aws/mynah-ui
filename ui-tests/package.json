{
    "name": "@amzn/mynah-website",
    "version": "1.0.0",
    "description": "",
    "main": "webpack.media.config.js",
    "scripts": {
        "clean": "rm -rf build dist node_modules",
        "tests:prepare": "webpack --config webpack.config.js --mode development",
